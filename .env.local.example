# ──────────────────────────────────────────────────────────────
# Configuracoes para TESTE LOCAL com Informix Developer Edition
# Use este arquivo quando estiver testando com Informix instalado
# localmente. Copie para .env e ajuste conforme necessario.
# ──────────────────────────────────────────────────────────────

# Nivel de log: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=DEBUG

# Origens permitidas pelo CORS (separadas por virgula)
CORS_ORIGINS=http://localhost:5173

# Senha padrao atribuida a novos usuarios (trocada no primeiro login)
DEFAULT_PASSWORD=temp1234

# Titulo exibido na documentacao da API (Swagger)
APP_TITLE=Sistema Sefaz - Dev Local

# ──────────────────────────────────────────────────────────────
# INFORMIX LOCAL - Developer Edition
# Estes sao os valores PADRAO da instalacao Developer Edition
# Ajuste se voce configurou diferente
# ──────────────────────────────────────────────────────────────

# Nome do servidor Informix (padrao do Developer Edition)
INFORMIX_SERVER=ol_informix1210

# Nome do banco de dados que voce criou
INFORMIX_DATABASE=sefaz_test

# Host local
INFORMIX_HOST=localhost

# Porta padrao
INFORMIX_PORT=9088

# Usuario padrao do Developer Edition
INFORMIX_USER=informix

# Senha padrao do Developer Edition (mude se alterou na instalacao)
INFORMIX_PASSWORD=in4mix

# Protocolo
INFORMIX_PROTOCOL=onsoctcp
