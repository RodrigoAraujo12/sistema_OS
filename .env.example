# ──────────────────────────────────────────────────────────────
# Configuracoes do Sistema Sefaz
# Copie este arquivo como .env e ajuste conforme necessario.
# ──────────────────────────────────────────────────────────────

# Nivel de log: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Origens permitidas pelo CORS (separadas por virgula)
CORS_ORIGINS=http://localhost:5173

# Senha padrao atribuida a novos usuarios (trocada no primeiro login)
DEFAULT_PASSWORD=temp1234

# Titulo exibido na documentacao da API (Swagger)
APP_TITLE=Sistema Sefaz

# ──────────────────────────────────────────────────────────────
# Configuracoes do Banco Informix (SERVIDOR REMOTO)
# Se nao configuradas, o sistema usara dados MOCK para desenvolvimento
# ──────────────────────────────────────────────────────────────

# Nome do servidor Informix (ex: ol_informix1170)
INFORMIX_SERVER=

# Nome do banco de dados (ex: sefaz_db)
INFORMIX_DATABASE=

# Host/IP do servidor (ex: 192.168.1.100 ou servidor.sefaz.local)
INFORMIX_HOST=

# Porta do servico Informix (padrao: 9088)
INFORMIX_PORT=9088

# Usuario do banco de dados
INFORMIX_USER=

# Senha do usuario
INFORMIX_PASSWORD=

# Protocolo de conexao (padrao: onsoctcp)
INFORMIX_PROTOCOL=onsoctcp
